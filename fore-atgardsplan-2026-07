<script>
// Filterchips
const chips = document.querySelectorAll('.chip');
chips.forEach(c => c.addEventListener('click', () => {
  chips.forEach(x => x.classList.remove('on'));
  c.classList.add('on');
  const f = c.dataset.f;
  document.querySelectorAll('.finding').forEach(el =>
    el.classList.toggle('hide', f !== 'alla' && el.dataset.s !== f));
}));
// Accordion
document.querySelectorAll('.phase-head').forEach(h =>
  h.addEventListener('click', () => h.parentElement.classList.toggle('open')));
// Progress (endast i minnet under sessionen)
const boxes = document.querySelectorAll('.step input');
const pf = document.getElementById('pf'), pl = document.getElementById('pl');
function upd(){
  const done = [...boxes].filter(b => b.checked).length;
  pf.style.width = (done / boxes.length * 100) + '%';
  pl.textContent = done + ' av ' + boxes.length + ' steg avprickade';
  boxes.forEach(b => b.closest('.step').classList.toggle('done', b.checked));
}
boxes.forEach(b => b.addEventListener('change', upd));
upd();
</script>
